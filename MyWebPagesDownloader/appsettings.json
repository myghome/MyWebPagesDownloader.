{
  "Downloader": {
    "MaxConcurrentWorkers": 5,
    "ChannelCapacity": 1000,
    "TimeoutSeconds": 30,
    "OutputPath": "./downloads"
  },
  "Retry": {
    "MaxRetries": 3,
    "InitialDelayMilliseconds": 100,
    "MaxDelayMilliseconds": 5000,
    "BackoffMultiplier": 2.0
  },
  "Storage": {
    "OutputPath": "./downloads",
    "CompressContent": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
